# =============================================================================
# P-Chat .gitignore
# =============================================================================
# Order matters within a section: more specific patterns first.
# Lines starting with `#` are comments; blank lines separate sections.
#
# To verify nothing leaks: `git status --ignored` and `git check-ignore -v <path>`.
# =============================================================================


# -----------------------------------------------------------------------------
# Agent tool symlinks (.opencode / .claude / .codex → .agents)
# -----------------------------------------------------------------------------
# This project only uses .agents/. The other three are symlinks or
# copies created by .agents/scripts/install.ps1 for compatibility.
.opencode/
.claude/
.codex/


# -----------------------------------------------------------------------------
# Go build artifacts
# -----------------------------------------------------------------------------
# Project-local bin/ output of `go build ./...` and `Taskfile.yml` targets.
bin/
# Stale build outputs left in the repo root from `go build -o pchat.exe`.
/pchat
/pchat.exe
/pchat-server
/pchat-server.exe
/pchat-gui
/pchat-gui.exe
# Test binaries (Go writes them next to the package on `go test -c`).
*.test
*.test.exe
*.out
# Coverage profiles (`go test -coverprofile=...`).
coverage.out
coverage.html
*.cover
*.coverprofile
# Go workspace (multi-module) — only relevant if a developer opts in locally.
/go.work
/go.work.sum

# -----------------------------------------------------------------------------
# Vendored / downloaded dependencies
# -----------------------------------------------------------------------------
vendor/
# `go mod download` cache is in $GOPATH/pkg/mod, never in-repo, but be safe.
.gocache/

# -----------------------------------------------------------------------------
# P-Chat runtime state
# -----------------------------------------------------------------------------
# Global runtime directory: ~/.p-chat/  (per paths.GlobalDirName).
# This is the per-user store of secrets, memory DB, and tools cache.
# NEVER commit this — it contains the user's SQLite memory and any
# per-provider API keys that override the on-disk config.
.p-chat/
# Legacy pre-0.4 names (kept until we're sure nobody has them).
.pchat/
# Project-local runtime (e.g. AGENTS.md / .p-chat/ inside a project
# when running `pchat` inside a code repo). Committed by `pchat init`
# *is* allowed — the project's own .p-chat/AGENTS.md is content.
# We only ignore generated state inside .p-chat/, not the dir itself.

# Memory database: SQLite + WAL + SHM sidecars. These end up inside
# ~/.p-chat/memory/ but path them explicitly in case someone symlinks
# the data dir into the project.
*.db
*.db-journal
*.db-wal
*.db-shm

# Legacy memory file (pre-SQLite).
memory.json
conversations.json

# Knowledge base index (rebuilt on scan; large binary blobs).
.p-chat/knowledge/
.pchat/knowledge/

# -----------------------------------------------------------------------------
# Test scratch
# -----------------------------------------------------------------------------
# `test_http/` is a manual smoke-test scratch dir created during HTTP
# refactors. It contains captured server.out/server.err and is
# reproducible.
test_http/
# Generic scratch dirs that the test commands sometimes use.
scratch/
tmp/
.tmp/

# -----------------------------------------------------------------------------
# Local config overrides
# -----------------------------------------------------------------------------
# configs/config.yaml IS the committed template (with empty api_key
# fields). Users drop their real keys into a sibling .local file.
configs/*.local.yaml
configs/*.local.yml
# Any file that explicitly contains credentials. Even with the *.local
# pattern above, a stray `api_key: sk-...` in the tracked config.yaml
# would still be committed — keep the broad secret fallback.
*.secret.yaml
*.secrets.yaml
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Server logs and runtime output
# -----------------------------------------------------------------------------
*.log
server.log
server.err
server.out
*.out
*.err

# -----------------------------------------------------------------------------
# Operating system noise
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
# Linux
*~

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
# IntelliJ / GoLand / WebStorm
.idea/
*.iml
*.iws
*.ipr
# VS Code
.vscode/
# Sublime Text
*.sublime-project
*.sublime-workspace
# Vim / Emacs
*.swp
*.swo
*~
.*.sw[a-z]
\#*\#
.\#*
# JetBrains scratch / run configs
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries
.idea/shelf/

# -----------------------------------------------------------------------------
# Build / packaging outputs from CI
# -----------------------------------------------------------------------------
# release.yml writes to dist/ on the runner; we never want to commit
# that locally either.
dist/
artifacts/
*.tar.gz
*.zip
# Compiled object / linker files.
*.o
*.a
*.so
*.dylib
*.dll

# -----------------------------------------------------------------------------
# Coverage / profiling reports
# -----------------------------------------------------------------------------
*.prof
*.pprof
*.trace
.pgo/

# -----------------------------------------------------------------------------
# Node / Vite / Vue tooling
# -----------------------------------------------------------------------------
node_modules/
.next/
.nuxt/
.cache/
.parcel-cache/
*.min.js
*.min.css
*.bundle.js
*.bundle.css
# Vite + TypeScript incremental build caches.
*.tsbuildinfo
.vite/
.turbo/
# yarn/pnpm lockfiles (npm-only project; this enforces the choice).
yarn.lock
pnpm-lock.yaml
# `package-lock.json` IS committed (npm standard).

# -----------------------------------------------------------------------------
# Vite build output (SPA)
# -----------------------------------------------------------------------------
# web/index.html and web/assets/** are written by `vite build` (see
# Taskfile.yml `build:frontend`). The script
# `scripts/clean-frontend-output.ps1` wipes both before each build to
# keep the bundle size bounded. They are NOT source.
web/index.html
web/assets/

# -----------------------------------------------------------------------------
# Wails generated bindings / build outputs
# -----------------------------------------------------------------------------
# Wails writes a generated Go-binding TypeScript shim under
# frontend/wailsjs/go/ on every `wails build` / `wails dev`. We do
# not version-control that — it is reproducible from the Go side.
# `wailsjs/runtime/` is the Wails runtime helpers shipped as a node
# package (declared in wailsjs/runtime/package.json) and IS
# committed.
frontend/wailsjs/go/
# Wails build/ dir contains the compiled `pchat-gui.exe` plus a
# generated `windows/info.json` / `windows/wails.exe.manifest` /
# `appicon.png`. We keep the assets (icons, manifest) and ignore
# the rest. (The `cmd/pchat-gui/.gitignore` already covers
# `build/bin` and `node_modules`; this rule covers everything
# else under build/ that we don't want.)
cmd/pchat-gui/build/bin/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
# Local override file for editor / tooling settings
.local/
# Anything that starts with "tmp" or ends in ".bak"
*.bak
*.tmp
*.orig
*.rej
*.swp
*.swo
# Backup files from various editors
*.goutputstream-*
*.kate-swp
# task (https://taskfile.dev) scratch dir. `task --status` writes
# here on Windows; safe to ignore.
.task/

# =============================================================================
# Allowed exceptions
# =============================================================================
# If a file matches an ignore above but you really need to commit it,
# use `git add -f <path>` to override. Common legitimate cases:
#   - .gitkeep in otherwise-empty dirs
#   - .github/workflows/* is committed
#   - configs/config.yaml is committed (template)
# =============================================================================

# Generated by sync:web (scripts/sync-web.ps1) before each build.
# //go:embed in cmd/pchat-server requires the directory to exist at
# compile time, so we keep cmd/pchat-server/web/.gitkeep committed
# and only ignore the generated output inside.
cmd/pchat-server/web/index.html
cmd/pchat-server/web/assets/
# Ad-hoc dev binaries built straight from the source tree (e.g.
# `go build -o cmd/pchat-server/pchat-server.exe`). The release
# bundle lives at cmd/pchat-gui/build/bin/, not here.
cmd/pchat-server/pchat-server.exe
cmd/pchat/pchat.exe
cmd/pchat-gui/pchat-gui.exe
# Installer build artifacts (generated by scripts/build-installer.ps1).
cmd/pchat-installer/assets/
# Installer output.
/bin/pchat-setup*.exe
/pchat-installer.exe
# Dev build output (task build:dev).
dev-bin/
